generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum FlowVisibility {
  private
  shared
  public
}

enum FlowStatus {
  draft
  published
  archived
}

enum FlowSessionStatus {
  active
  completed
  abandoned
}

enum FlowAccessRole {
  viewer
  editor
}

model User {
  id            String       @id @default(uuid())
  email         String       @unique
  password      String
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  flows         Flow[]
  sharedFlows   FlowAccess[]

  @@index([email])
}

model Flow {
  id            String         @id @default(uuid())
  title         String
  description   String?
  visibility    FlowVisibility
  status        FlowStatus
  graph         Json?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  ownerId       String?
  owner         User?          @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  sessions      FlowSession[]
  accessList    FlowAccess[]

  @@index([ownerId])
  @@index([visibility])
}

model FlowAccess {
  id            String         @id @default(uuid())
  flowId        String
  userId        String
  role          FlowAccessRole
  createdAt     DateTime       @default(now())

  flow          Flow           @relation(fields: [flowId], references: [id], onDelete: Cascade)
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([flowId, userId])
  @@index([flowId])
  @@index([userId])
}

model FlowSession {
  id            String            @id @default(uuid())
  flowId        String
  currentNodeId String
  status        FlowSessionStatus @default(active)
  context       Json?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  flow          Flow              @relation(fields: [flowId], references: [id], onDelete: Cascade)

  @@index([flowId, status])
}