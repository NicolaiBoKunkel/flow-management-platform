generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum FlowVisibility {
  private
  shared
  public
}

enum FlowStatus {
  draft
  published
  archived
}

model Flow {
  id          String         @id @default(uuid())
  title       String
  description String?
  visibility  FlowVisibility
  status      FlowStatus
  graph       Json?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}