      "item": [
        {
          "name": "API-005 Create Flow",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Flow creation succeeds\", function () {\r",
                  "  pm.response.to.have.status(201);\r",
                  "});\r",
                  "\r",
                  "const json = pm.response.json();\r",
                  "\r",
                  "pm.test(\"Response contains flow id\", function () {\r",
                  "  pm.expect(json.id).to.be.a(\"string\");\r",
                  "});\r",
                  "\r",
                  "pm.environment.set(\"flowId\", json.id);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
