        {
          "name": "API-005 Save Valid Graph",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"API-005 valid flow save returns 200\", function () {\r",
                  "  pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "const json = pm.response.json();\r",
                  "\r",
                  "pm.test(\"Response contains graph\", function () {\r",
                  "  pm.expect(json.graph).to.be.an(\"object\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response contains nodes\", function () {\r",
                  "  pm.expect(json.graph.nodes.length).to.eql(3);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response contains edges\", function () {\r",
                  "  pm.expect(json.graph.edges.length).to.eql(2);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "PATCH",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"graph\": {\r\n    \"nodes\": [\r\n      {\r\n        \"id\": \"start-node\",\r\n        \"type\": \"start\",\r\n        \"label\": \"Start\",\r\n        \"position\": {\r\n          \"x\": 0,\r\n          \"y\": 0\r\n        }\r\n      },\r\n      {\r\n        \"id\": \"question-node\",\r\n        \"type\": \"question\",\r\n        \"label\": \"Question\",\r\n        \"questionType\": \"singleChoice\",\r\n        \"position\": {\r\n          \"x\": 200,\r\n          \"y\": 100\r\n        }\r\n      },\r\n      {\r\n        \"id\": \"end-node\",\r\n        \"type\": \"end\",\r\n        \"label\": \"End\",\r\n        \"position\": {\r\n          \"x\": 400,\r\n          \"y\": 200\r\n        }\r\n      }\r\n    ],\r\n    \"edges\": [\r\n      {\r\n        \"id\": \"edge-start-question\",\r\n        \"source\": \"start-node\",\r\n        \"target\": \"question-node\"\r\n      },\r\n      {\r\n        \"id\": \"edge-question-end\",\r\n        \"source\": \"question-node\",\r\n        \"target\": \"end-node\"\r\n      }\r\n    ]\r\n  }\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/flows/{{flowId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "flows",
                "{{flowId}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "API-001 Reject Invalid Graph",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"API-001 invalid graph save returns 400\", function () {\r",
                  "  pm.response.to.have.status(400);\r",
                  "});\r",
                  "\r",
                  "const json = pm.response.json();\r",
                  "\r",
                  "pm.test(\"Response has validation failure message\", function () {\r",
                  "  pm.expect(json.message).to.eql(\"Flow graph validation failed\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response has errors array\", function () {\r",
                  "  pm.expect(json.errors).to.be.an(\"array\");\r",
                  "  pm.expect(json.errors.length).to.be.greaterThan(0);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Errors mention missing nodes\", function () {\r",
                  "  pm.expect(json.errors).to.include(\"Flow must contain at least one node.\");\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
