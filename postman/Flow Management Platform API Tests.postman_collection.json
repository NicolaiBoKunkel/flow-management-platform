      "name": "Auth",
      "item": [
        {
          "name": "AUTH-001A Register Owner",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"AUTH-001 owner register returns 201 or already exists\", function () {\r",
                  "  pm.expect([201, 409]).to.include(pm.response.code);\r",
                  "});\r",
                  "\r",
                  "if (pm.response.code === 201) {\r",
                  "  const json = pm.response.json();\r",
                  "\r",
                  "  pm.test(\"Response contains owner token\", function () {\r",
                  "    pm.expect(json.accessToken).to.be.a(\"string\");\r",
                  "  });\r",
                  "\r",
                  "  pm.environment.set(\"accessToken\", json.accessToken);\r",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"email\": \"{{ownerEmail}}\",\r\n  \"password\": \"{{ownerPassword}}\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
